{
  "nodes": [
    {
      "parameters": {
        "jsCode": "const welcomeText = `👋 *Welcome to WeatherAI Bot!*\\n\\nHere's what I can do for you:\\n\\n🌤 *Get weather by city*\\nJust type a city name e.g. _Nairobi_, _Mombasa_, _Kisumu_\\n\\n📍 *Get weather for your current location*\\n*Android:* Tap the attachment icon → Location → Send current location\\n*iPhone:* Tap the + icon → Location\\n\\n🌳 *Analyse your farm trees*\\nSend a photo of your farm and I'll analyse tree health and canopy coverage.\\n\\n---\\n_Powered by WeatherAI_`;\n\nreturn [{ json: { message: welcomeText, chatId: $json.chatId, session: $json.session } }];"
      },
      "id": "27ad1b15-3049-42d4-ade3-db2f6b8131ff",
      "name": "Build welcome message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -96,
        8016
      ]
    },
    {
      "parameters": {
        "jsCode": "const w = $input.first().json;\nconst sessionGate = $('Session gate1').first().json;\nconst chatId = sessionGate.chatId;\nconst session = sessionGate.session;\n\n// Safely extract the main object in case it's wrapped in an array\nlet weatherData = w;\nif (!w.current && Array.isArray(w) && w.length > 0 && w[0].current) {\n    weatherData = w[0];\n}\n\nif (!weatherData.current) {\n  return [{ json: { message: `Sorry, I couldn't find weather for that location.`, chatId, session } }];\n}\n\nconst temp = weatherData.current?.temperature ? Math.round(weatherData.current.temperature) : 'N/A';\nconst conditionCode = String(weatherData.current?.condition_code || '');\n\n// Expanded WMO Condition Codes with emojis\nconst conditionMap = {\n  '0': 'Clear sky ☀️', '1': 'Mainly clear 🌤', '2': 'Partly cloudy ⛅️', '3': 'Overcast ☁️',\n  '45': 'Fog 🌫', '48': 'Depositing rime fog 🌫',\n  '51': 'Light drizzle 🌦', '53': 'Moderate drizzle 🌧', '55': 'Dense drizzle 🌧',\n  '56': 'Light freezing drizzle 🌧❄️', '57': 'Dense freezing drizzle 🌧❄️',\n  '61': 'Slight rain 🌧', '63': 'Moderate rain 🌧', '65': 'Heavy rain 🌧',\n  '66': 'Light freezing rain 🌧❄️', '67': 'Heavy freezing rain 🌧❄️',\n  '71': 'Slight snow 🌨', '73': 'Moderate snow 🌨', '75': 'Heavy snow ❄️',\n  '77': 'Snow grains ❄️',\n  '80': 'Light rain showers 🌦', '81': 'Moderate rain showers 🌧', '82': 'Violent rain showers ⛈',\n  '85': 'Slight snow showers 🌨', '86': 'Heavy snow showers ❄️',\n  '95': 'Thunderstorm ⛈', '96': 'Thunderstorm, slight hail ⛈❄️', '99': 'Thunderstorm, heavy hail ⛈❄️'\n};\n\nconst conditionDesc = conditionMap[conditionCode] || conditionCode || 'Unknown';\n\n// Safely determine if this was a geocoded query to add the city name\nlet cityNameStr = '';\ntry {\n  // If this came from the Live Location branch, accessing $('Check Geocode1') throws an error.\n  // The try/catch block ensures it fails silently and gracefully for Live Location!\n  const geoResults = $('Check Geocode1').first()?.json?.results;\n  if (geoResults && geoResults.length > 0) {\n    cityNameStr = ` for ${geoResults[0].name}`;\n  }\n} catch (error) {\n  // Node did not execute, so this was a Live Location query! (Do nothing)\n}\n\nlet message = `*Weather at your location${cityNameStr}* 📍\\n\\n`;\nmessage += `🌡 *Currently:* ${temp}°C\\n`;\nmessage += `🌤 *Conditions:* ${conditionDesc}\\n`;\n\nif (weatherData.current?.wind_speed) {\n    message += `💨 *Wind:* ${weatherData.current.wind_speed} km/h\\n`;\n}\nmessage += `\\n`;\n\n// AI Summary\nconst aiSummary = weatherData.ai_summary || '';\nif (aiSummary) message += `💡 _${aiSummary}_\\n\\n`;\n\n// Daily Forecast (Next 3 days)\nlet dailyData = weatherData.daily || weatherData.forecast || weatherData.forecasts;\nif (!dailyData && Array.isArray(w) && w.length > 0 && w[0].date) dailyData = w;\nelse if (!dailyData && Array.isArray(weatherData) && weatherData[0] && weatherData[0].date) dailyData = weatherData;\nelse if (!dailyData && Array.isArray(w) && Array.isArray(w[0])) dailyData = w[0];\n\nif (dailyData && Array.isArray(dailyData) && dailyData.length > 0) {\n    message += `*📅 Forecast:*\\n`;\n    const forecastDays = dailyData.slice(0, 3); // Grab up to the next 3 days\n    \n    forecastDays.forEach(day => {\n        if (!day.date) return;\n        const dateObj = new Date(day.date);\n        const dayStr = dateObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });\n        \n        const dMin = Math.round(day.temp_min);\n        const dMax = Math.round(day.temp_max);\n        const dCode = String(day.condition_code || '');\n        const dCond = conditionMap[dCode] || dCode;\n        const dRainProb = day.precipitation_probability ? `${day.precipitation_probability}%` : '0%';\n        \n        message += `• *${dayStr}*: ${dMin}°C - ${dMax}°C | ${dCond} (Rain: ${dRainProb})\\n`;\n    });\n}\n\nreturn [{ json: { message, chatId, session } }];"
      },
      "id": "e4599139-744d-4a34-b5ff-65e1738a1ee9",
      "name": "Format Weather Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -96,
        7824
      ]
    },
    {
      "parameters": {
        "jsCode": "const res = $input.first().json;\nconst sessionGate = $('Session gate1').first().json;\nconst chatId = sessionGate.chatId;\nconst session = sessionGate.session;\n\n// Helper to safely get values\nconst totalTrees = res.total_tree_count ?? 0;\nconst landAcres = res.land_acres ?? null;\nconst confidence = res.confidence_score ?? 0;\nconst lowConfidence = res.low_confidence === true;\nconst health = res.tree_health || { healthy: 0, needs_care: 0, needs_replacement: 0 };\nconst observations = Array.isArray(res.observations) ? res.observations : [];\nconst recommendations = Array.isArray(res.recommendations) ? res.recommendations : [];\n\n// Start building the message\nlet message = \"🌳 *Tree Analysis Results*\\n\\n\";\n\n// Case: no trees detected or very low confidence\nif (totalTrees === 0 || lowConfidence) {\n  message += \"We couldn't identify any trees clearly from the image you provided. \";\n  message += \"This can happen if the photo is blurry, taken from far away, or doesn't show trees prominently.\\n\\n\";\n  message += \"📸 *Tip:* Try taking a clearer photo of your trees from a closer angle, and make sure the area is well-lit.\\n\\n\";\n  if (res.gemini_error) {\n    // Mask internal error – don't expose API key issues\n    message += \"_Note: Our analysis service is temporarily limited. We're working to improve it._\";\n  }\n} else {\n  // Normal analysis with detected trees\n  message += `📊 *Detected:* ${totalTrees} tree${totalTrees !== 1 ? 's' : ''}`;\n  if (landAcres) {\n    const density = (totalTrees / landAcres).toFixed(1);\n    message += ` on ${landAcres} acre${landAcres !== 1 ? 's' : ''} (≈ ${density} trees/acre)`;\n  }\n  message += \"\\n\\n\";\n\n  // Tree health summary\n  const healthy = health.healthy || 0;\n  const needsCare = health.needs_care || 0;\n  const needsReplace = health.needs_replacement || 0;\n  message += \"🌿 *Health status:*\\n\";\n  message += `✅ Healthy: ${healthy}\\n`;\n  message += `⚠️ Needs care: ${needsCare}\\n`;\n  message += `🔄 Needs replacement: ${needsReplace}\\n\\n`;\n\n  // Observations (if any)\n  if (observations.length > 0) {\n    message += \"🔍 *Observations:*\\n\";\n    observations.forEach(obs => { message += `• ${obs}\\n`; });\n    message += \"\\n\";\n  }\n\n  // Recommendations (if any)\n  if (recommendations.length > 0) {\n    message += \"💡 *Recommendations:*\\n\";\n    recommendations.forEach(rec => { message += `• ${rec}\\n`; });\n    message += \"\\n\";\n  }\n\n  // Confidence note\n  if (confidence < 0.7) {\n    message += `⚠️ *Low confidence analysis* (${Math.round(confidence*100)}%). For best results, use a clear, well-lit photo taken closer to the trees.`;\n  }\n}\n\n// Return formatted message\nreturn [{ json: { message, chatId, session } }];"
      },

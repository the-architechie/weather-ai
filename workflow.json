    {
      "parameters": {
        "jsCode": "const payload = $json.body?.payload || {};\n\n// Ignore messages sent by the bot itself (prevents loops)\nif (payload.fromMe === true) {\n  return [];\n}\n\nconst text = (payload.body || '').trim();\nconst textLower = text.toLowerCase();\n\nconst hasLocation = !!payload.location;\nconst hasMedia = !!payload.media;\n\n// Common greetings\nconst greetings = ['hi', 'hello', 'hey', 'start', 'menu', 'jambo', 'niaje'];\nconst isWelcome = greetings.includes(textLower);\n\nlet action = 'send_help';\n\nif (hasLocation) {\n  action = 'location';\n} else if (hasMedia) {\n  action = 'image';\n} else if (isWelcome) {\n  action = 'welcome';\n} else if (textLower === 'help') {\n  action = 'send_help';\n} else if (text) {\n  // If it's standard text but not a greeting, treat it as a text query (city)\n  action = 'text';\n}\n\nreturn [\n  {\n    json: {\n      action,\n      chatId: payload.from || null,\n      session: $json.body?.session || null,\n      payload,\n      originalWebhook: $json\n    }\n  }\n];"
      },
